{
  "compilerOptions": {
    "target": "ES2020",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "outDir": "dist",
    "rootDir": ".",
    "strict": false,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "types": ["node"]
  },
  "include": [
    "server.ts",
    "index.ts",
    "oauth.ts",
    "context.ts",
    "routers/**/*.ts",
    "websocket.ts",
    "webhook-endpoint.ts",
    "withdrawal-notifications.ts",
    "wave-connector.ts"
  ],
  "exclude": [
    "node_modules",
    "dist",
    "vite.config.ts",
    "vitest.config.ts",
    "frontend",
    "src",
    "**/*.test.ts"
  ]
}
